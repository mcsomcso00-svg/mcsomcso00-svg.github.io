---
import Base from '../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const now = new Date();
  // 日期閘門：發布日 <= 今天才建置頁面 → 配合每日 cron 自動滴灌上線
  const posts = await getCollection('blog', (p) => !p.data.draft && p.data.date_published <= now);
  return posts.map((post) => {
    const [lang, ...rest] = post.id.split('/');
    return { params: { lang, slug: rest.join('/') }, props: { post } };
  });
}
const { post } = Astro.props;
const lang = Astro.params.lang as 'zh-hant' | 'zh-hans' | 'en';
const { Content } = await render(post);
const fmt = (d: Date) => d.toISOString().slice(0, 10);

// hreflang：本文 + frontmatter.translations 指到的其他語言版本
const selfPath = `/${lang}/blog/${post.id.split('/').slice(1).join('/')}/`;
const alternates: Record<string, string> = { [lang]: selfPath };
if (post.data.translations) {
  for (const [l, slug] of Object.entries(post.data.translations)) {
    alternates[l] = `/${l}/blog/${slug}/`;
  }
}

// Article schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  author: { '@type': 'Organization', name: post.data.author },
  publisher: { '@type': 'Organization', name: 'SemanticLab' },
  datePublished: post.data.date_published.toISOString(),
  dateModified: (post.data.date_updated ?? post.data.date_published).toISOString(),
  inLanguage: lang === 'en' ? 'en' : lang === 'zh-hans' ? 'zh-Hans' : 'zh-Hant',
  mainEntityOfPage: new URL(selfPath, Astro.site).toString(),
};

// 從內文「**Q1：...**\n答案段」自動抽 FAQPage schema（產線模板固定此格式）
const faqPairs: { q: string; a: string }[] = [];
const faqRe = /\*\*Q\d+[：:]\s*([^*]+?)\*\*\s*\n([^\n*][^\n]*(?:\n(?![*\n#])[^\n]+)*)/g;
let m;
while ((m = faqRe.exec(post.body ?? '')) !== null) {
  faqPairs.push({ q: m[1].trim(), a: m[2].trim().replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') });
}
const faqSchema =
  faqPairs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqPairs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;

const schemas = faqSchema ? [articleSchema, faqSchema] : [articleSchema];

const BC = {
  'zh-hant': { home: '首頁', blog: '部落格' },
  'zh-hans': { home: '首页', blog: '博客' },
  en: { home: 'Home', blog: 'Blog' },
}[lang];

// 相關文章：同群集、日期已上線、排除自己，取 3 篇（提升 session 深度）
const now = new Date();
const related = (
  await getCollection(
    'blog',
    (p) =>
      p.id.startsWith(`${lang}/`) &&
      !p.data.draft &&
      p.data.date_published <= now &&
      p.id !== post.id &&
      p.data.cluster === post.data.cluster
  )
)
  .sort((a, b) => b.data.date_published.valueOf() - a.data.date_published.valueOf())
  .slice(0, 3);

// 文末轉換卡文案
const CTA = {
  'zh-hant': {
    title: '想知道你的網站離「被 AI 引用」還有多遠？',
    desc: '30 秒免費檢測你的文章，或領取一份指名到頁面與段落的完整網站診斷報告。',
    primary: '免費領取診斷報告',
    secondary: '先用免費檢測器試試',
    related: '延伸閱讀',
  },
  'zh-hans': {
    title: '想知道你的网站离「被 AI 引用」还有多远？',
    desc: '30 秒免费检测你的文章，或领取一份指名到页面与段落的完整网站诊断报告。',
    primary: '免费领取诊断报告',
    secondary: '先用免费检测器试试',
    related: '延伸阅读',
  },
  en: {
    title: 'How far is your site from being cited by AI?',
    desc: 'Check any article free in 30 seconds, or get a full site diagnosis report pinned to exact pages and paragraphs.',
    primary: 'Get my free audit report',
    secondary: 'Try the free checker first',
    related: 'Related articles',
  },
}[lang];
const breadcrumbs = [
  { name: BC.home, url: `/${lang}/` },
  { name: BC.blog, url: `/${lang}/blog/` },
  { name: post.data.title, url: selfPath },
];
---
<Base
  title={post.data.title}
  description={post.data.description ?? ''}
  lang={lang}
  alternates={alternates}
  schemas={schemas}
  breadcrumbs={breadcrumbs}
>
  <article>
    <p class="post-meta">
      {post.data.author} · {fmt(post.data.date_published)}
      {post.data.date_updated && ` · 更新 ${fmt(post.data.date_updated)}`}
      {post.data.cluster && ` · ${post.data.cluster}`}
    </p>
    <Content />
  </article>

  <aside class="post-cta">
    <p class="post-cta-title">{CTA.title}</p>
    <p class="post-cta-desc">{CTA.desc}</p>
    <div class="post-cta-btns">
      <a class="post-cta-btn" href={`/${lang}/audit/`}>{CTA.primary}</a>
      <a class="post-cta-link" href={`/${lang}/geo/`}>{CTA.secondary} →</a>
    </div>
  </aside>

  {related.length > 0 && (
    <section class="related">
      <h2>{CTA.related}</h2>
      <ul class="card-list">
        {related.map((p) => (
          <li>
            <a href={`/${lang}/blog/${p.id.split('/').slice(1).join('/')}/`}>{p.data.title}</a>
            <p>{p.data.description}</p>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .post-cta {
    margin-top: 40px; padding: 24px 26px; border-radius: 14px;
    background: linear-gradient(135deg, #1a2740, #171b22);
    border: 1px solid #2f4a7a;
  }
  .post-cta-title { font-size: 18px; font-weight: 800; margin: 0 0 6px; }
  .post-cta-desc { color: var(--dim); font-size: 14px; margin: 0 0 16px; }
  .post-cta-btns { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .post-cta-btn {
    background: var(--cta); color: var(--cta-ink) !important; text-decoration: none;
    font-weight: 700; font-size: 15px; padding: 12px 22px; border-radius: 10px;
    box-shadow: var(--cta-glow); transition: filter .2s;
  }
  .post-cta-btn:hover { filter: brightness(1.08); }
  .post-cta-link { font-size: 14px; }
  .related h2 { margin-top: 36px; }
</style>
