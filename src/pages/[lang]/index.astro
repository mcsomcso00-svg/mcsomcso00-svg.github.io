---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'zh-hant' } }, { params: { lang: 'zh-hans' } }, { params: { lang: 'en' } }];
}
const lang = Astro.params.lang as 'zh-hant' | 'zh-hans' | 'en';

const T = {
  'zh-hant': {
    title: 'SemanticLab — SEO / GEO 實戰內容',
    desc: '用語意集群方法經營的 SEO/GEO 部落格：讓你的內容被 Google 排名、被 ChatGPT/Perplexity/AI Overview 引用。',
    h1: '讓內容被 Google 排名，也被 AI 引用',
    intro: '這裡用「語意集群 → Boss 頁面 → 功能工具」的方法，公開實作一個會成長的 SEO/GEO 網站。',
    latest: '最新文章',
    tool: '免費工具：GEO 就緒度檢測器',
    toolDesc: '貼上文章，30 秒拿到 0–100 分與逐項修正建議。',
  },
  'zh-hans': {
    title: 'SemanticLab — SEO / GEO 实战内容',
    desc: '用语义集群方法经营的 SEO/GEO 博客：让你的内容被 Google 排名、被 ChatGPT/Perplexity/AI Overview 引用。',
    h1: '让内容被 Google 排名，也被 AI 引用',
    intro: '这里用「语义集群 → Boss 页面 → 功能工具」的方法，公开实作一个会成长的 SEO/GEO 网站。',
    latest: '最新文章',
    tool: '免费工具：GEO 就绪度检测器',
    toolDesc: '粘贴文章，30 秒拿到 0–100 分与逐项修改建议。',
  },
  en: {
    title: 'SemanticLab — Practical SEO / GEO Content',
    desc: 'An SEO/GEO blog built with the semantic-cluster method: rank on Google and get cited by ChatGPT, Perplexity, and AI Overview.',
    h1: 'Rank on Google. Get cited by AI.',
    intro: 'A build-in-public SEO/GEO site using the semantic cluster → Boss page → functional tool method.',
    latest: 'Latest articles',
    tool: 'Free tool: GEO Readiness Checker',
    toolDesc: 'Paste an article, get a 0–100 score with specific fixes in 30 seconds.',
  },
}[lang];

const now = new Date();
const posts = (await getCollection('blog', (p) => p.id.startsWith(`${lang}/`) && !p.data.draft && p.data.date_published <= now))
  .sort((a, b) => b.data.date_published.valueOf() - a.data.date_published.valueOf());

const alternates = { 'zh-hant': '/zh-hant/', 'zh-hans': '/zh-hans/', en: '/en/' };
---
<Base title={T.title} description={T.desc} lang={lang} alternates={alternates}>
  <h1>{T.h1}</h1>
  <p>{T.intro}</p>

  <h2>{T.tool}</h2>
  <p>{T.toolDesc} → <a href={`/${lang}/geo/`}>GEO Checker</a></p>

  <h2>{T.latest}</h2>
  {posts.length === 0 ? (
    <p style="color:var(--dim)">Coming soon.</p>
  ) : (
    <ul class="card-list">
      {posts.map((p) => (
        <li>
          <a href={`/${lang}/blog/${p.id.split('/').slice(1).join('/')}/`}>{p.data.title}</a>
          <p>{p.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</Base>
