---
import Base from '../../../layouts/Base.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh-hant' } }, { params: { lang: 'zh-hans' } }, { params: { lang: 'en' } }];
}
const lang = Astro.params.lang as 'zh-hant' | 'zh-hans' | 'en';

// 諮詢 CTA 的聯絡方式：之後換成正式信箱或表單連結（Tally/Google Form）只改這兩行
// Boss 頁 B1：群集精簡總整理 + 內嵌功能工具（護城河）
const T = {
  'zh-hant': {
    title: 'GEO 就緒度檢測器 — 你的內容夠格被 AI 引用嗎？',
    desc: '免費 GEO 檢測工具：貼上文章，30 秒拿到 0–100 分與九項訊號的修正建議。附 GEO 方法論總整理。',
    h1: 'GEO 就緒度檢測器',
    lead: 'GEO（生成式引擎優化）的目標，是讓 ChatGPT、Perplexity、Google AI Overview 在回答時引用你。這個免費工具用九個可驗證的訊號替你的文章打分，並告訴你具體要改哪裡。',
    how: '評分方法（也是 GEO 的九個核心訊號）',
    signals: [
      '答案優先開頭：前 40–80 字給出自包含結論',
      '可引用數據：數字、百分比、日期、價格',
      '結構與標題：清楚的 H2/H3 階層',
      '問題／FAQ：貼近使用者與 AI 的提問方式',
      '清單／表格：利於 AI 摘要與引用',
      '內容深度：把單一意圖完整答完',
      '實體清晰度：品牌／作者明確可歸屬',
      '來源／連結：可信引用與內鏈',
      '時效性：明確的發布／更新日期',
    ],
    read: '延伸閱讀',
    ctaTitle: '免費領取你的「詳細 SEO／GEO 健檢診斷報告」',
    ctaDesc: '這不是通用清單。我們用你的真實網址跑一份深入診斷，逐項列出你網站到底哪裡出問題、附上實際頁面與段落舉例——讓你清楚看見為什麼 Google 與 AI 冷落你。',
    ctaFreeLabel: '免費診斷報告包含',
    ctaFreePoints: [
      'GEO 就緒度：九項訊號逐頁掃描分數，＋你「沒被 AI 引用」的具體原因與段落舉例',
      '內容負債盤點：90 天 0 點擊頁面清單，＋在拖垮你的技術問題定位',
      '競爭落差：你 vs 前 3 名對手的語意覆蓋與被引用差距',
      '每個問題都指名道姓到「哪一頁、哪一段」，不是空泛評語',
    ],
    ctaPaidLabel: '付費升級（實際「怎麼修」的建議）',
    ctaPaidPoints: [
      '每個問題的具體修正做法＋逐頁改寫範本與 Schema 實作',
      '依影響力排序的修正優先清單＋90 天執行藍圖',
      '語意集群與內鏈架構設計，或直接交給我們代操',
    ],
    ctaBtn: '免費領取健檢診斷報告',
    ctaNote: '免費報告詳列「問題」；完整「修正建議」與執行為付費項目。名額有限，來信／填表請附上你的網站網址。',
  },
  'zh-hans': {
    title: 'GEO 就绪度检测器 — 你的内容够格被 AI 引用吗？',
    desc: '免费 GEO 检测工具：粘贴文章，30 秒拿到 0–100 分与九项信号的修改建议。附 GEO 方法论总整理。',
    h1: 'GEO 就绪度检测器',
    lead: 'GEO（生成式引擎优化）的目标，是让 ChatGPT、Perplexity、Google AI Overview 在回答时引用你。这个免费工具用九个可验证的信号为你的文章打分，并告诉你具体要改哪里。',
    how: '评分方法（也是 GEO 的九个核心信号）',
    signals: [
      '答案优先开头：前 40–80 字给出自包含结论',
      '可引用数据：数字、百分比、日期、价格',
      '结构与标题：清楚的 H2/H3 层级',
      '问题／FAQ：贴近用户与 AI 的提问方式',
      '清单／表格：利于 AI 摘要与引用',
      '内容深度：把单一意图完整答完',
      '实体清晰度：品牌／作者明确可归属',
      '来源／链接：可信引用与内链',
      '时效性：明确的发布／更新日期',
    ],
    read: '延伸阅读',
    ctaTitle: '免费领取你的「详细 SEO／GEO 健检诊断报告」',
    ctaDesc: '这不是通用清单。我们用你的真实网址跑一份深入诊断，逐项列出你网站到底哪里出问题、附上实际页面与段落举例——让你清楚看见为什么 Google 与 AI 冷落你。',
    ctaFreeLabel: '免费诊断报告包含',
    ctaFreePoints: [
      'GEO 就绪度：九项信号逐页扫描分数，＋你「没被 AI 引用」的具体原因与段落举例',
      '内容负债盘点：90 天 0 点击页面清单，＋在拖垮你的技术问题定位',
      '竞争落差：你 vs 前 3 名对手的语义覆盖与被引用差距',
      '每个问题都指名道姓到「哪一页、哪一段」，不是空泛评语',
    ],
    ctaPaidLabel: '付费升级（实际「怎么修」的建议）',
    ctaPaidPoints: [
      '每个问题的具体修改做法＋逐页改写范本与 Schema 实作',
      '按影响力排序的修改优先清单＋90 天执行蓝图',
      '语义集群与内链架构设计，或直接交给我们代操',
    ],
    ctaBtn: '免费领取健检诊断报告',
    ctaNote: '免费报告详列「问题」；完整「修改建议」与执行为付费项目。名额有限，来信／填表请附上你的网站网址。',
  },
  en: {
    title: 'GEO Readiness Checker — Is your content citable by AI?',
    desc: 'Free GEO tool: paste an article, get a 0–100 score across nine verifiable signals with specific fixes. Includes the GEO methodology.',
    h1: 'GEO Readiness Checker',
    lead: 'GEO (Generative Engine Optimization) is about getting cited by ChatGPT, Perplexity, and Google AI Overview. This free tool scores your article on nine verifiable signals and tells you exactly what to fix.',
    how: 'How scoring works (the nine core GEO signals)',
    signals: [
      'Answer-first opening: a self-contained conclusion in the first 40–80 words',
      'Quotable data: numbers, percentages, dates, prices',
      'Structure: clear H2/H3 hierarchy',
      'Questions / FAQ: matching how users and AI ask',
      'Lists / tables: easy for AI to summarize and cite',
      'Depth: fully answer one intent',
      'Entity clarity: attributable brand/author',
      'Sources / links: credible citations and internal links',
      'Freshness: visible publish/update dates',
    ],
    read: 'Further reading',
    ctaTitle: 'Get your detailed SEO / GEO audit report — free',
    ctaDesc: "Not a generic checklist. We run a deep diagnosis on your real URL and list exactly what's wrong, with the actual pages and paragraphs as evidence — so you see why Google and AI ignore you.",
    ctaFreeLabel: 'The free diagnosis report includes',
    ctaFreePoints: [
      'GEO readiness: per-page scores on nine signals, plus the specific reasons (with paragraph examples) AI is not citing you',
      'Content-debt inventory: your 90-day zero-click pages, plus the technical issues dragging you down',
      'Competitive gap: your semantic coverage & citation gap vs the top 3 competitors',
      'Every issue is pinned to a specific page and paragraph — not vague commentary',
    ],
    ctaPaidLabel: 'Paid upgrade (the actual "how to fix" recommendations)',
    ctaPaidPoints: [
      'The exact fix for each issue + per-page rewrite templates and schema implementation',
      'An impact-ranked fix priority list + a 90-day execution roadmap',
      'Semantic cluster & internal-linking architecture — or done-for-you implementation',
    ],
    ctaBtn: 'Get my free diagnosis report',
    ctaNote: 'The free report details the problems; the full fix recommendations and implementation are paid. Limited slots — please include your site URL.',
  },
}[lang];

// CTA 直接導到站內原生表單頁（Formsubmit 送出）
const ctaHref = `/${lang}/audit/`;

const alternates = { 'zh-hant': '/zh-hant/geo/', 'zh-hans': '/zh-hans/geo/', en: '/en/geo/' };
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: T.h1,
  applicationCategory: 'SEO Tool',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0' },
  publisher: { '@type': 'Organization', name: 'SemanticLab' },
};
---
<Base title={T.title} description={T.desc} lang={lang} alternates={alternates} schemas={[schema]}>
  <h1>{T.h1}</h1>
  <p>{T.lead}</p>

  <iframe class="tool-frame" src="/tools/geo-readiness-checker.html" title={T.h1} loading="lazy"></iframe>

  <section class="cta-card">
    <h2 class="cta-title">{T.ctaTitle}</h2>
    <p>{T.ctaDesc}</p>
    <div class="cta-cols">
      <div class="cta-col cta-free">
        <div class="cta-tag cta-tag-free">✓ {T.ctaFreeLabel}</div>
        <ul>{T.ctaFreePoints.map((p) => <li>{p}</li>)}</ul>
      </div>
      <div class="cta-col cta-paid">
        <div class="cta-tag cta-tag-paid">★ {T.ctaPaidLabel}</div>
        <ul>{T.ctaPaidPoints.map((p) => <li>{p}</li>)}</ul>
      </div>
    </div>
    <a class="cta-btn" href={ctaHref}>{T.ctaBtn}</a>
    <p class="cta-note">{T.ctaNote}</p>
  </section>

  <h2>{T.how}</h2>
  <ul>
    {T.signals.map((s) => <li>{s}</li>)}
  </ul>

  <h2>{T.read}</h2>
  <ul>
    {lang === 'zh-hant' ? (
      <>
        <li><a href="/zh-hant/blog/what-is-geo/">GEO 是什麼？生成式引擎優化完整定義（2026）</a></li>
        <li><a href="/zh-hant/blog/geo-vs-seo/">GEO 與傳統 SEO 有什麼不同？一張表看懂</a></li>
        <li><a href="/zh-hant/blog/geo-aeo-aio/">GEO、AEO、AIO 差在哪？三者關係一次搞懂</a></li>
      </>
    ) : (
      <li><a href={`/${lang}/blog/`}>Blog</a></li>
    )}
  </ul>
</Base>

<style>
  .cta-card {
    margin-top: 36px;
    background: linear-gradient(135deg, #1a2740, #171b22);
    border: 1px solid #2f4a7a;
    border-radius: 14px;
    padding: 28px 26px;
  }
  .cta-title { margin-top: 0; border-bottom: none; font-size: 21px; }
  .cta-cols { display: flex; gap: 16px; flex-wrap: wrap; margin: 18px 0 22px; }
  .cta-col { flex: 1; min-width: 240px; border-radius: 12px; padding: 16px 18px; }
  .cta-free { background: rgba(63,185,80,0.08); border: 1px solid rgba(63,185,80,0.35); }
  .cta-paid { background: rgba(79,140,255,0.07); border: 1px solid rgba(79,140,255,0.3); }
  .cta-tag { font-weight: 700; font-size: 13.5px; margin-bottom: 8px; }
  .cta-tag-free { color: var(--good); }
  .cta-tag-paid { color: var(--accent); }
  .cta-col ul { margin: 0; padding-left: 18px; color: var(--dim); }
  .cta-col li { margin: 6px 0; font-size: 13.5px; line-height: 1.55; }
  .cta-btn {
    display: inline-block;
    background: var(--cta);
    color: var(--cta-ink) !important;
    text-decoration: none;
    font-weight: 700;
    font-size: 16px;
    padding: 13px 26px;
    border-radius: 10px;
  }
  .cta-btn { box-shadow: var(--cta-glow); transition: filter .2s; }
  .cta-btn:hover { filter: brightness(1.08); }
  .cta-note { color: var(--dim); font-size: 12.5px; margin-top: 12px; margin-bottom: 0; }
</style>
