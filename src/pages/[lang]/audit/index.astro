---
import Base from '../../../layouts/Base.astro';
import { AUDIT_EMAIL, WEB3FORMS_KEY } from '../../../consts';

export function getStaticPaths() {
  return [{ params: { lang: 'zh-hant' } }, { params: { lang: 'zh-hans' } }, { params: { lang: 'en' } }];
}
const lang = Astro.params.lang as 'zh-hant' | 'zh-hans' | 'en';

const T = {
  'zh-hant': {
    title: '免費 SEO／GEO 健檢診斷報告 — SemanticLab',
    desc: '填一分鐘表單，我們用你的真實網址跑一份深入的 SEO/GEO 診斷，逐項列出問題與段落舉例。完整修正建議為付費項目。',
    h1: '免費領取你的「詳細 SEO／GEO 健檢診斷報告」',
    lead: '這不是通用清單。留下你的網址，我們會用九項 GEO 訊號逐頁掃描、盤點內容負債、比對前 3 名對手，指名到「哪一頁、哪一段」出問題。',
    freeLabel: '✓ 免費診斷報告詳列',
    free: [
      'GEO 就緒度逐頁分數＋你沒被 AI 引用的具體原因與段落舉例',
      '內容負債：90 天 0 點擊頁面清單＋技術問題定位',
      '你 vs 前 3 名對手的語意覆蓋與被引用落差',
    ],
    paidLabel: '★ 付費升級（實際怎麼修）',
    paid: [
      '每個問題的修正做法＋逐頁改寫範本與 Schema 實作',
      '依影響力排序的修正優先清單＋90 天執行藍圖，或直接代操',
    ],
    fName: '稱呼（選填）',
    fEmail: 'Email（必填，用來寄報告）',
    fUrl: '你的網站網址（必填）',
    fMarket: '目標市場／語言（選填，例：台灣、繁中＋英文）',
    fMsg: '你最想解決的問題（選填）',
    submit: '免費領取健檢診斷報告',
    note: '免費報告詳列「問題」；完整「修正建議」與執行為付費項目。我們不會把你的資料用於行銷名單。',
    subject: '【SemanticLab】免費 SEO/GEO 健檢診斷報告索取',
  },
  'zh-hans': {
    title: '免费 SEO／GEO 健检诊断报告 — SemanticLab',
    desc: '填一分钟表单，我们用你的真实网址跑一份深入的 SEO/GEO 诊断，逐项列出问题与段落举例。完整修改建议为付费项目。',
    h1: '免费领取你的「详细 SEO／GEO 健检诊断报告」',
    lead: '这不是通用清单。留下你的网址，我们会用九项 GEO 信号逐页扫描、盘点内容负债、比对前 3 名对手，指名到「哪一页、哪一段」出问题。',
    freeLabel: '✓ 免费诊断报告详列',
    free: [
      'GEO 就绪度逐页分数＋你没被 AI 引用的具体原因与段落举例',
      '内容负债：90 天 0 点击页面清单＋技术问题定位',
      '你 vs 前 3 名对手的语义覆盖与被引用落差',
    ],
    paidLabel: '★ 付费升级（实际怎么修）',
    paid: [
      '每个问题的修改做法＋逐页改写范本与 Schema 实作',
      '按影响力排序的修改优先清单＋90 天执行蓝图，或直接代操',
    ],
    fName: '称呼（选填）',
    fEmail: 'Email（必填，用来寄报告）',
    fUrl: '你的网站网址（必填）',
    fMarket: '目标市场／语言（选填，例：台湾、繁中＋英文）',
    fMsg: '你最想解决的问题（选填）',
    submit: '免费领取健检诊断报告',
    note: '免费报告详列「问题」；完整「修改建议」与执行为付费项目。我们不会把你的资料用于营销名单。',
    subject: '【SemanticLab】免费 SEO/GEO 健检诊断报告索取',
  },
  en: {
    title: 'Free SEO / GEO Audit Diagnosis Report — SemanticLab',
    desc: 'Fill a one-minute form and we run a deep SEO/GEO diagnosis on your real URL, listing issues with paragraph-level evidence. Full fix recommendations are paid.',
    h1: 'Get your detailed SEO / GEO audit report — free',
    lead: "Not a generic checklist. Leave your URL and we'll scan every page on nine GEO signals, inventory your content debt, and benchmark you against the top 3 competitors — pinned to the exact page and paragraph.",
    freeLabel: '✓ The free report details',
    free: [
      'Per-page GEO readiness scores + why AI is not citing you, with paragraph examples',
      'Content debt: your 90-day zero-click pages + the technical issues behind them',
      'Your semantic coverage & citation gap vs the top 3 competitors',
    ],
    paidLabel: '★ Paid upgrade (the actual fixes)',
    paid: [
      'The exact fix per issue + per-page rewrite templates and schema implementation',
      'An impact-ranked fix list + 90-day roadmap, or done-for-you implementation',
    ],
    fName: 'Name (optional)',
    fEmail: 'Email (required — where we send the report)',
    fUrl: 'Your website URL (required)',
    fMarket: 'Target market / languages (optional, e.g. US, EN + zh-Hant)',
    fMsg: 'What you most want to fix (optional)',
    submit: 'Get my free diagnosis report',
    note: 'The free report details the problems; full fix recommendations and implementation are paid. We never use your data for marketing lists.',
    subject: '[SemanticLab] Free SEO/GEO audit diagnosis request',
  },
}[lang];

const alternates = { 'zh-hant': '/zh-hant/audit/', 'zh-hans': '/zh-hans/audit/', en: '/en/audit/' };
// Web3Forms：無帳號表單後端（formsubmit.co 在部分網路 DNS 被擋，已換掉）
const action = 'https://api.web3forms.com/submit';
const thanksPath = `/${lang}/audit/thanks/`;
const BC = {
  'zh-hant': { home: '首頁' }, 'zh-hans': { home: '首页' }, en: { home: 'Home' },
}[lang];
const breadcrumbs = [
  { name: BC.home, url: `/${lang}/` },
  { name: T.h1, url: `/${lang}/audit/` },
];
---
<Base title={T.title} description={T.desc} lang={lang} alternates={alternates} breadcrumbs={breadcrumbs}>
  <h1>{T.h1}</h1>
  <p>{T.lead}</p>

  <div class="recap">
    <div class="recap-col recap-free">
      <div class="recap-tag tag-free">{T.freeLabel}</div>
      <ul>{T.free.map((p) => <li>{p}</li>)}</ul>
    </div>
    <div class="recap-col recap-paid">
      <div class="recap-tag tag-paid">{T.paidLabel}</div>
      <ul>{T.paid.map((p) => <li>{p}</li>)}</ul>
    </div>
  </div>

  <form class="audit-form" action={action} method="POST"
        data-thanks={thanksPath} data-fallback={AUDIT_EMAIL} data-subject={T.subject}>
    <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
    <input type="hidden" name="subject" value={T.subject} />
    <input type="hidden" name="from_name" value="SemanticLab Audit Form" />
    <!-- 蜜罐：機器人才會填，Web3Forms 會擋掉 -->
    <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

    <label>{T.fName}<input type="text" name="name" autocomplete="name" /></label>
    <label>{T.fEmail}<input type="email" name="email" required autocomplete="email" /></label>
    <label>{T.fUrl}<input type="url" name="website" required placeholder="https://" /></label>
    <label>{T.fMarket}<input type="text" name="market" /></label>
    <label>{T.fMsg}<textarea name="message" rows="4"></textarea></label>
    <button type="submit">{T.submit}</button>
    <p class="form-note">{T.note}</p>
  </form>
</Base>

<script>
  // JS 送出＋雙保險：端點失敗（DNS 被擋/斷線）時自動退回 mailto，不漏任何一筆申請
  const form = document.querySelector('form.audit-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button')!;
    const orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = '…';
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      const json = await res.json();
      if (!json.success) throw new Error(json.message || 'submit failed');
      location.href = form.dataset.thanks!;
    } catch {
      // 備援：開啟使用者的郵件程式，內容已預填
      const body = ['name', 'email', 'website', 'market', 'message']
        .map((k) => `${k}: ${data.get(k) || ''}`)
        .join('\n');
      location.href = `mailto:${form.dataset.fallback}?subject=${encodeURIComponent(form.dataset.subject!)}&body=${encodeURIComponent(body)}`;
      btn.disabled = false;
      btn.textContent = orig;
    }
  });
</script>

<style>
  .recap { display: flex; gap: 16px; flex-wrap: wrap; margin: 22px 0 30px; }
  .recap-col { flex: 1; min-width: 240px; border-radius: 12px; padding: 16px 18px; }
  .recap-free { background: rgba(63,185,80,0.08); border: 1px solid rgba(63,185,80,0.35); }
  .recap-paid { background: rgba(79,140,255,0.07); border: 1px solid rgba(79,140,255,0.3); }
  .recap-tag { font-weight: 700; font-size: 13.5px; margin-bottom: 8px; }
  .tag-free { color: var(--good); }
  .tag-paid { color: var(--accent); }
  .recap-col ul { margin: 0; padding-left: 18px; color: var(--dim); }
  .recap-col li { margin: 6px 0; font-size: 13.5px; line-height: 1.55; }
  .audit-form { display: flex; flex-direction: column; gap: 14px; background: var(--panel); border: 1px solid var(--line); border-radius: 14px; padding: 24px; }
  .audit-form label { display: flex; flex-direction: column; gap: 6px; font-size: 14px; color: var(--dim); }
  .audit-form input, .audit-form textarea { background: #0e1116; border: 1px solid var(--line); color: var(--txt); border-radius: 9px; padding: 11px 12px; font-size: 15px; font-family: inherit; }
  .audit-form input:focus, .audit-form textarea:focus { outline: none; border-color: var(--accent); }
  .audit-form button { margin-top: 4px; background: var(--accent); color: #fff; border: none; font-weight: 700; font-size: 16px; padding: 14px; border-radius: 10px; cursor: pointer; }
  .audit-form button:hover { filter: brightness(1.1); }
  .form-note { color: var(--dim); font-size: 12.5px; margin: 4px 0 0; }
</style>
